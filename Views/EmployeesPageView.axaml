<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:WorkSchedulerApp.ViewModels"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
    xmlns:m="clr-namespace:WorkSchedulerApp.Models"
    x:Class="WorkSchedulerApp.Views.EmployeesPageView"
    x:DataType="vm:EmployeesPageViewModel"
    mc:Ignorable="d"
    Background="{DynamicResource PrimaryBackground}"
    Foreground="{DynamicResource PrimaryForeground}"
    d:DesignWidth="1100"
    d:DesignHeight="800">

    <Design.DataContext>
        <vm:EmployeesPageViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.ColumnSpan="2">
            <svg:Svg Path="/Assets/Images/Banner.svg"
                     Height="140"
                     Stretch="UniformToFill" />

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Label Content="Employees" Classes="h2" />
                <Label Content="Manage employee details and schedules" />
            </StackPanel>
        </Grid>

        <!-- LEFT COLUMN: Employee List -->
        <StackPanel Grid.Row="1" Grid.Column="0" Margin="25" Spacing="15">
            <Label Classes="h2" Content="Employee List" />
            <TextBlock Text="{Binding Employees.Count, StringFormat='Total: {0} employees'}"/>

            <ListBox ItemsSource="{Binding Employees}"
                     SelectedItem="{Binding SelectedEmployee}"
                     Height="500">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="m:Employee">
                        <Border Margin="2" Padding="6" CornerRadius="8"
                                Background="{DynamicResource SecondaryBackground}">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Role}" FontSize="12"/>
                                <TextBlock Text="{Binding Availability}" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Refresh" Command="{Binding LoadEmployeesCommand}" />
                <Button Content="Delete Selected"
                        Command="{Binding DeleteEmployeeCommand}"
                        IsEnabled="{Binding CanDelete}" />
            </StackPanel>
        </StackPanel>

        <!-- RIGHT COLUMN: Employee Details -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="25">
            <StackPanel Spacing="15">

                <Label Classes="h2" Content="Employee Details" />

                <!-- BASIC FIELDS (Employee DataContext) -->
                <StackPanel DataContext="{Binding EditingEmployee}">
                    <TextBox Watermark="Full Name" Text="{Binding Name}" />
                    <TextBox Watermark="Role" Text="{Binding Role}" />
                    <NumericUpDown Minimum="0" Maximum="80" Value="{Binding RequestedHours}" />
                    <TextBox Watermark="Availability (Mon-Fri 9-17)" Text="{Binding Availability}" />
                    <TextBox Watermark="Contracted Hours" Text="{Binding ContractedHours}" />
                </StackPanel>

                <!-- SKILLS SECTION (Back to ViewModel) -->
                <Label Content="Skills" FontWeight="Bold" Margin="0,10,0,0"/>

                <!-- Skill chips -->
                <ItemsControl ItemsSource="{Binding SkillsForUI}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WorkLoadTemplateVM">
                            <Border Padding="6" Margin="2" CornerRadius="8"
                                    Background="{DynamicResource SecondaryBackground}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Name}" />
                                    <Button Content="×"
                                            Command="{Binding $parent[UserControl].DataContext.RemoveSkillCommand}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add a skill -->
                <ComboBox ItemsSource="{Binding AvailableSkills}"
                          SelectedItem="{Binding SelectedAvailableSkill}"
                          PlaceholderText="Select a skill...">

                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:WorkLoadTemplateVM">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>

                </ComboBox>


                <Button Content="Add Skill"
                        Command="{Binding AddSkillCommand}" />

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Add"
                            Command="{Binding AddEmployeeCommand}"
                            IsVisible="{Binding !BoolSelectedEmployee}" />

                    <Button Content="Update"
                            Command="{Binding UpdateEmployeeCommand}"
                            IsVisible="{Binding BoolSelectedEmployee}" />

                    <Button Content="Clear Fields"
                            Command="{Binding ClearFieldsCommand}" />

                    <Button Content="Delete"
                            Command="{Binding DeleteEmployeeCommand}"
                            IsVisible="{Binding BoolSelectedEmployee}"
                            Classes="Alert"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
