<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="WorkScedulerApp.Views.WorkPageView"
             xmlns:vm="clr-namespace:WorkScedulerApp.ViewModels"
             x:DataType="vm:WorkPageViewModel">
    <Design.DataContext><vm:WorkPageViewModel></vm:WorkPageViewModel></Design.DataContext>
    
    <Label Content="{Binding Test}"></Label>
</UserControl>
