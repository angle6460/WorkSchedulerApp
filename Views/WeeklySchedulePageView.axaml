<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:WorkSchedulerApp.ViewModels"
    x:Class="WorkSchedulerApp.Views.WeeklySchedulePageView"
    x:DataType="vm:WeeklySchedulePageViewModel"
    Foreground="{DynamicResource PrimaryForeground}"
    Background="{DynamicResource PrimaryBackground}">
    
    <Design.DataContext><vm:WeeklySchedulePageViewModel></vm:WeeklySchedulePageViewModel></Design.DataContext>

    <Grid ColumnDefinitions="2*, 3*" Margin="20">

        <!-- Left side: Create new schedule -->
        <StackPanel Grid.Column="0" Spacing="15">
            <TextBlock Text="Create Weekly Schedule" FontSize="20"/>

            <TextBlock Text="Template:"/>
            <ComboBox ItemsSource="{Binding Templates}"
                      SelectedItem="{Binding SelectedTemplate}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:WeeklyTemplateSummary">
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Start Date:"/>
            <DatePicker SelectedDate="{Binding SelectedStartDate}"/>

            <Button Content="Create Schedule"
                    Command="{Binding CreateScheduleCommand}"
                    IsEnabled="{Binding SelectedTemplate}"/>
        </StackPanel>

        <!-- Right side: Existing schedules + detailed view -->
        <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" RowSpacing="10">

            <!-- Title -->
            <TextBlock Text="Existing Schedules" FontSize="20" Grid.Row="0"/>

            <!-- List of schedules -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Schedules}"
                     SelectedItem="{Binding SelectedSchedule}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:WeeklyScheduleSummary">
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Range}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding TemplateLabel}" FontSize="12"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Detailed schedule view -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="500">
                <StackPanel Spacing="12" Margin="5">

                    <TextBlock Text="Schedule Details"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <TextBlock Text="{Binding SelectedSchedule.Range}" />
                    <TextBlock Text="{Binding SelectedSchedule.TemplateLabel}" />

                    <!-- Days List -->
                    <ItemsControl ItemsSource="{Binding DayDetails}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:DayInstanceDetail">

                                <StackPanel Margin="0,10,0,0">

                                    <TextBlock Text="{Binding DayName}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Margin="0,5"/>

                                    <!-- Workloads -->
                                    <ItemsControl ItemsSource="{Binding Workloads}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:WorkLoadInstanceDetail">

                                                <Border BorderThickness="1"
                                                        Padding="8"
                                                        Margin="5"
                                                        CornerRadius="8"
                                                        Background="{DynamicResource SecondaryBackground}"
                                                        BorderBrush="{DynamicResource BorderSubtle}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontSize="12"/>
                                                        <TextBlock Text="{Binding Type}"
                                                                   FontSize="10"
                                                                   FontStyle="Italic"/>
                                                        <TextBlock Text="{Binding EstimatedHours, StringFormat='Hours: {0:F1}'}"
                                                                   FontSize="12"/>
                                                    </StackPanel>
                                                </Border>

                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Actions -->
                    <Button Content="Auto Assign Employees"
                            Command="{Binding AutoAssignCommand}"
                            IsEnabled="{Binding SelectedSchedule}"
                            Margin="0,10,0,0"/>
                    <Button Content="Export Assigned Employees"
                            Command="{Binding ExportAssignedEmployeesCommand}"
                            IsEnabled="{Binding SelectedSchedule}"
                            Margin="0,10,0,0"/>

                    <Button Content="Delete Schedule"
                            Command="{Binding DeleteScheduleCommand}"
                            IsEnabled="{Binding SelectedSchedule}"/>

                </StackPanel>
            </ScrollViewer>


        </Grid>

    </Grid>
</UserControl>
